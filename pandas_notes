# 七、分组与聚合（groupby，数据分析核心，3-4小时）
# df.groupby("目标列").agg({"保留列的名称1":"要求","保留列的名称2":"要求"}),结束后将目标列存为新的index
# 1. 基础分组聚合（按1列分组）
df_sales = pd.DataFrame({ "地区": ["北京", "北京", "上海", "上海", "北京"],
                          "日期": ["2023-01", "2023-02", "2023-01", "2023-02", "2023-03"],
                          "销售额(万)": [150, 180, 200, 220, 210],
                          "利润(万)": [30, 36, 40, 44, 42] })

# 1. 按“地区”分组，算销售额和利润的总和
grouped1 = df_sales.groupby("地区").agg({ "销售额(万)": "sum","利润(万)":"sum"}).reset_index()
# 销售额求和       # 利润求和
# reset_index：把“地区”从索引变回列
print(grouped1)
#    地区  销售额(万)  利润(万)
# 0  上海     420     84
# 1  北京     540    108
grouped2=df_sales.groupby("日期").agg({"销售额(万)": "max","利润(万)":"sum"})
print(grouped2)
#          销售额(万)  利润(万)
# 日期
# 2023-01     200     70
# 2023-02     220     80
# 2023-03     210     42

# 2. 按“地区”分组，算多个统计指标（sum+mean+max）
grouped2 = df_sales.groupby("地区").agg({ "销售额(万)": ["sum", "mean", "max"],"利润(万)": "mean"}).reset_index()
# 销售额：总和、均值、最大值  # 利润：均值
print(grouped2)
#    地区 销售额(万)             利润(万)
#          sum   mean  max  mean
# 0  上海    420  210.0  220  42.0
# 1  北京    540  180.0  210  36.0

# 1. 多列分组（更细粒度的分析）
grouped_multi = df_sales.groupby(["地区", "日期"]).agg({ "销售额(万)": "sum", "利润(万)": "mean" }).reset_index()
print(grouped_multi)
#    地区       日期  销售额(万)  利润(万)
# 0  上海  2023-01     200   40.0
# 1  上海  2023-02     220   44.0
# 2  北京  2023-01     150   30.0
# 3  北京  2023-02     180   36.0
# 4  北京  2023-03     210   42.0
# 输出结果：每行是“地区+月份”的组合，对应销售额和平均利润

# 1. 分组后过滤（筛选符合条件的组）
# 步骤1：分组算总销售额
# 分组计算后sum>500的行保留
grouped_filter = df_sales.groupby("地区").filter( lambda x: x["销售额(万)"].sum() > 500)
print(grouped_filter)
